    "expo-clipboard": "^8.0.8",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "^19.0.22",
    "expo-mail-composer": "^15.0.8",
    "expo-print": "~15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-speech": "^14.0.8",
    "jszip": "^3.10.1",
    "pako": "^2.1.0",
