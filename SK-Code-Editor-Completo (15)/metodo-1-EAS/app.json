        "backgroundColor": "#0d1117"
      },
      "package": "com.skeditor.app",
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE", "CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "owner": "TROQUE_PELO_SEU_USUARIO_EXPO",
    "extra": {
      "eas": { "projectId": "GERE_EM_expo.dev_APOS_LOGIN" }
    }
  }
