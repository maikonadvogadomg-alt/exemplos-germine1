{
  "expo": {
    "name": "Assistente Jurídico",
    "slug": "assistente-juridico",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "assistentejuridico",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.maikonrocha.assistentejuridico"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "br.com.maikonrocha.assistentejuridico",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        { "microphonePermission": "Permitir acesso ao microfone para ditado por voz." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "maikonrocha"
  }
}
